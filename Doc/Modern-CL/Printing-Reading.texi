@item @href{Type wb-set, wb-set} @tab @code{#@{ @i{e0} @i{e1} @dots{} @}[@i{compare-fn}]} @tab 1, 3
@item @href{Type ch-set, ch-set} @tab @code{##@{ @i{e0} @i{e1} @dots{} @}[@i{compare-fn}]} @tab 2, 3
@item @href{Type complement-set, complement-set} @tab @code{~@i{set}} @tab 4
