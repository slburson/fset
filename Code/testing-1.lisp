(defun test-champ-sets (n)
  (declare (optimize (speed 0) (debug 3)))
  (macrolet ((test (form)
	       `(unless ,form
		  (error "Test failed: ~S" ',form))))
    (let ((saved-wbs nil)
	  (saved-chs nil))
      (dotimes (i n)
	(when (zerop (mod i 10))
	  (format t "."))
	(let ((cfn (if (zerop (mod i 4)) 'erapmoc 'compare))
	      (wbs (wb-set))
	      ((chs (ch-custom-set cfn))
	       ((tchs (make-transient chs))))
	      (use-seq-of-symbols? (= 7 (ldb (byte 3 1) i))))
	  ;; I had this at 256, but that was too high: it forced almost all the maps to have four
	  ;; full or nearly-full levels, making certain scenarios improbable -- and bugs lurked there.
	  (dotimes (j (+ 64 (random 128)))
	    (let ((mi (if use-seq-of-symbols?
			  (@ *seq-of-symbols* (random (size *seq-of-symbols*)))
			(make-my-integer (random 1024))))
		  (prev-wbs wbs)
		  (prev-chs chs))
	      (test (eqv (contains? chs mi) (contains? wbs mi)))
	      (test (eqv (contains? chs mi) (contains? tchs mi)))
	      (test (or (empty? chs) (contains? chs (arb chs))))
	      (if (< (random 100) 20)
		  (progn
		    (excludef wbs mi)
		    (excludef chs mi)
		    (exclude! tchs mi)
		    (unless (or (contains? prev-wbs mi)
				(eq chs prev-chs))
		      (error "ch-set less failed to detect no change")))
		(progn
		  (includef wbs mi)
		  (includef chs mi)
		  (include! tchs mi)))
	      (test (verify chs))
	      (test (verify tchs))
	      (test (= (size chs) (size wbs)))
	      ;; The API doesn't expose a way to do this; must use internals directly.
	      (test (eq (ch-set-tree-compare (ch-set-contents chs) (transient-ch-set-contents tchs) #'compare)
			':equal))
	      (test (equal? (make-persistent tchs :copy? t) chs))
	      (test (equal? (convert 'wb-set chs) wbs))
	      (test (eqv (subset? chs prev-chs) (subset? wbs prev-wbs)))
	      (when (let ((quot rem (floor j 32)))
		      (and (= 0 rem) (>= quot 1)))
		(let ((elts (wb-set)))
		  (dotimes (k (size chs))
		    (includef elts (at-index chs k)))
		  (unless (equal? elts wbs)
		    (error "ch-set at-index failed")))
		(unless use-seq-of-symbols?
		  (let ((idx (random (size chs)))
			((elt (at-index chs idx))
			 ((tmp-chs (with (less chs elt)
					 ;; Adding 4096 doesn't change the hash value.
					 (make-my-integer (+ (my-integer-value elt) 4096)))))))
		    ;; `ch-set-tree-compare' is tough to test thoroughly.  This at least checks the case that is
		    ;; least obviously correct by inspection, where all the hash values are the same but two elements
		    ;; nonetheless differ.
		    (when (eq (compare-fn-name chs) 'compare)
		      (test (and (eq (compare chs tmp-chs) ':less)
				 (eq (compare tmp-chs chs) ':greater)))))
		  (let ((chs-p0 chs-p1 (partition (fn (x) (evenp (my-integer-value x))) chs))
			(wbs-p0 wbs-p1 (partition (fn (x) (evenp (my-integer-value x))) wbs)))
		    (test (equal? (convert 'wb-set chs-p0) wbs-p0))
		    (test (equal? chs-p1 (convert 'ch-set wbs-p1 :compare-fn-name (compare-fn-name chs)))))
		  (let ((chs-p0 chs-p1 (fset2:partition (fn (x) (evenp (my-integer-value x))) chs))
			(wbs-p0 wbs-p1 (fset2:partition (fn (x) (evenp (my-integer-value x))) wbs)))
		    (test (equal? (convert 'wb-set chs-p0) wbs-p0))
		    (test (equal? chs-p1 (convert 'ch-set wbs-p1 :compare-fn-name (compare-fn-name chs))))))
		(test (equal? chs (convert 'ch-set wbs :compare-fn-name (compare-fn-name chs))))
		(test (equal? chs (convert 'ch-set (convert 'seq wbs) :compare-fn-name (compare-fn-name chs))))
		(test (equal? chs (convert 'ch-set (convert 'vector wbs) :compare-fn-name (compare-fn-name chs))))
		(let ((k 0)
		      (it (iterator chs))
		      (f-it (fun-iterator chs))
		      (t-it (make-ch-set-tree-iterator (transient-ch-set-contents tchs))))
		  (do-set (x chs)
		    (test (equal? x (at-index chs k)))
		    (test (funcall it ':more?))
		    (test (not (funcall f-it ':empty?)))
		    (let ((itval (funcall it ':get))
			  (f-itval (funcall f-it ':first)))
		      (test (equal? x itval))
		      (test (equal? x f-itval)))
		    (test (= (index chs x) k))
		    (incf k)
		    (setq f-it (funcall f-it ':rest))
		    (test (not (funcall t-it ':done?)))
		    (test (equal? x (funcall t-it ':get))))
		  (test (funcall it ':done?))
		  (test (funcall f-it ':empty?))
		  (test (funcall t-it ':done?)))
		(test (equal? (reverse (convert 'seq chs))
			      (gmap (:result seq) nil (:arg fun-sequence chs :from-end? t)))))))
	  (when saved-chs
	    (flet ((check-pref (result label &optional right?)
		     (let ((bad (gmap :or (fn (x) (let ((sx? sx (lookup result x)))
						    (and sx? (not (eq x sx)) x)))
				      (:arg set (if right? saved-chs chs)))))
		       (when bad
			 (error "~A failed ~:[left~;right~] preference: ~A"
				label right? bad)))))
	      (let ((chs-union (union chs saved-chs)))
		(test (verify chs-union))
		(test (equal? (convert 'wb-set chs-union) (union wbs saved-wbs)))
		(check-pref chs-union "Set union"))
	      (let ((chs-intersection (intersection chs saved-chs)))
		(test (verify chs-intersection))
		(test (equal? (convert 'wb-set chs-intersection) (intersection wbs saved-wbs)))
		(check-pref chs-intersection "Set intersection"))
	      (let ((chs-diff (set-difference chs saved-chs)))
		(test (verify chs-diff))
		(test (equal? (convert 'wb-set chs-diff) (set-difference wbs saved-wbs)))
		(check-pref chs-diff "Set difference")
		(let ((chs-diff-2a chs-diff-2b (set-difference-2 chs saved-chs)))
		  (test (verify chs-diff-2a))
		  (test (verify chs-diff-2b))
		  (test (equal? chs-diff-2a chs-diff))
		  (test (equal? chs-diff-2b (set-difference saved-chs chs)))
		  (check-pref chs-diff-2a "Set difference-2")
		  (check-pref chs-diff-2b "Set difference-2" t)))))
	  ;; To get a good test for `disjoint?', we need different statistics -- choosing 256 out of 1024,
	  ;; disjointness is astronomically unlikely.  Choosing 55 out of 4096 gives roughly 50% odds.
	  ;; (Why so few?  The Birthday Paradox.)
	  (let ((wbs0 (gmap (:result wb-set) (fn (_i) (make-my-integer (random 4096))) (:arg index 0 55)))
		(wbs1 (gmap (:result wb-set) (fn (_i) (make-my-integer (random 4096))) (:arg index 0 55)))
		((chs0 (convert 'ch-set wbs0))
		 (chs1 (convert 'ch-set wbs1))))
	    (test (eqv (disjoint? chs0 chs1) (disjoint? wbs0 wbs1))))
	  (setq saved-wbs wbs)
	  (setq saved-chs chs))))))

(defmethod verify ((m ch-map))
  (let ((hmorg (ch-map-org m)))
    (ch-map-tree-verify (ch-map-contents m) (hash-map-org-key-hash-fn hmorg) (hash-map-org-val-hash-fn hmorg))))

(defmethod verify ((m transient-ch-map))
  (let ((hmorg (transient-ch-map-org m)))
    (ch-map-tree-verify (transient-ch-map-contents m)
			(hash-map-org-key-hash-fn hmorg) (hash-map-org-val-hash-fn hmorg))))

(defvar *champ-map-test-pairs* (seq))

(defun test-champ-maps (n)
  (declare (optimize (speed 0) (debug 3)))
  (macrolet ((test (form)
	       `(unless ,form
		  (error "Test failed: ~S" ',form))))
    (let ((saved-wbm nil)
	  (saved-chm nil))
      (dotimes (i n)
	(when (zerop (mod i 10))
	  (format t "."))
	(let ((cfn (if (zerop (mod i 4)) 'erapmoc 'compare))
	      (wbm (wb-map))
	      ((chm (ch-custom-map cfn nil))
	       ((tchm (make-transient chm))))
	      (use-seq-of-symbols? (= 7 (ldb (byte 3 1) i))))
	  (setq *champ-map-test-pairs* (seq))
	  (dotimes (j (+ 64 (random 128)))
	    (let ((mi (if use-seq-of-symbols?
			  (@ *seq-of-symbols* (random (size *seq-of-symbols*)))
			(make-my-integer (random 1024))))
		  (val (make-my-integer (random 128)))
		  (prev-wbm wbm)
		  (prev-chm chm))
	      (test (eql (lookup chm mi) (lookup wbm mi)))
	      (test (eql (lookup chm mi) (lookup! tchm mi)))
	      (test (or (empty? chm) (let ((k v (arb chm)))
				       (equal? v (lookup chm k)))))
	      (if (< (random 100) 20)
		  (progn
		    (push-last *champ-map-test-pairs* (list '- mi val))
		    (excludef wbm mi)
		    (excludef chm mi)
		    (exclude! tchm mi)
		    (test (or (domain-contains? prev-wbm mi)
			      (eq chm prev-chm))))
		(progn
		  (push-last *champ-map-test-pairs* (list '+ mi val))
		  (setf (@ wbm mi) val)
		  (setf (@ chm mi) val)
		  (setf (lookup! tchm mi) val)))
	      (when (< (random 100) 5)
		;; Cause value hashes to be cached, triggering incremental updating.
		(hash-value chm))
	      (test (verify chm))
	      (test (verify tchm))
	      (test (eq (ch-map-tree-compare (ch-map-contents chm) (transient-ch-map-contents tchm)
					     #'compare #'hash-value #'compare)
			':equal))
	      (test (equal? (make-persistent tchm :copy? t) chm))
	      (when (let ((quot rem (floor j 32)))
		      (and (= 0 rem) (>= quot 1)))
		(let ((wbm-from-ch (convert 'wb-map chm)))
		  (unless (equal? wbm wbm-from-ch)
		    (error "ch-map equal? failed on ~A~%vs. ~A:~%diffs ~A~%prev ~A" wbm chm
			   (multiple-value-list (map-difference-2 wbm wbm-from-ch)) prev-chm)))
		(let ((ch-dom (domain chm)))
		  (test (verify ch-dom))
		  (test (equal? (convert 'wb-set ch-dom) (domain wbm))))
		(unless use-seq-of-symbols?
		  (let ((idx (random (size chm)))
			((elt (at-index chm idx))
			 ((chm-less-elt tval (less chm elt))
			  ((tmp-chm (with chm-less-elt
					  ;; Adding 4096 doesn't change the hash value.
					  (make-my-integer (+ (my-integer-value elt) 4096))
					  (@ chm elt)))))))
		    (test (verify chm-less-elt))
		    (test (equal? tval (@ chm elt)))
		    (test (verify tmp-chm))
		    ;; `ch-map-tree-compare' is tough to test thoroughly.  This at least checks the case that is
		    ;; least obviously correct by inspection, where all the hash values are the same but two elements
		    ;; nonetheless differ.
		    (when (eq (key-compare-fn-name chm) 'compare)
		      (test (eq (compare chm tmp-chm) ':less))
		      (test (eq (compare tmp-chm chm) ':greater)))))
		(let ((k 0)
		      (it (iterator chm))
		      (f-it (fun-iterator chm))
		      (t-it (make-ch-map-tree-iterator (transient-ch-map-contents tchm))))
		  (do-map (x y chm)
		    (let ((idxx idxy (at-index chm k)))
		      (test (and (equal? x idxx) (equal? y idxy))))
		    (test (funcall it ':more?))
		    (test (not (funcall f-it ':empty?)))
		    (let ((it-x it-y (funcall it ':get))
			  (f-it-x f-it-y (funcall f-it ':first)))
		      (test (and (equal? x it-x) (equal? y it-y)))
		      (test (and (equal? x f-it-x) (equal? y f-it-y))))
		    (test (= (index chm x) k))
		    (incf k)
		    (setq f-it (funcall f-it ':rest))
		    (test (not (funcall t-it ':done?)))
		    (let ((t-it-x t-it-y (funcall t-it ':get)))
		      (test (and (equal? x t-it-x) (equal? y t-it-y)))))
		  (test (funcall it ':done?))
		  (test (funcall f-it ':empty?))
		  (test (funcall t-it ':done?)))
		(test (equal? (reverse (convert 'seq chm))
			      (gmap (:result seq) #'cons (:arg fun-map chm :from-end? t)))))))
	  (test (equal? (compose chm (fn (y) (and y (my-integer-value y))))
			(gmap (:result ch-map :key-compare-fn-name cfn)
			      (fn (x y) (values x (my-integer-value y)))
			      (:arg ch-map chm))))
	  (flet ((filter-mod-8 (x y)
		   (declare (ignore x))
		   (if (zerop (mod (my-integer-value y) 8))
		       (values nil ':no-value)
		     y))
		 (check-pref (result source label &optional right?)
		   (let ((bad (gmap :or (fn (k v) (let ((mv mv? mk (lookup result k)))
						    (and mv? (or (not (eq k mk))
								 (and (equal? v mv) (not (eql v mv))))
							 k)))
				    (:arg map source))))
		     (when bad
		       (error "~A failed ~:[left~;right~] preference on iteration ~D: ~A"
			      label right? i bad)))))
	    (when saved-chm
	      (let ((chm-union (map-union chm saved-chm #'filter-mod-8)))
		(test (verify chm-union))
		(let ((wbm-union (map-union wbm saved-wbm #'filter-mod-8))
		      ((chm-union-as-wbm (convert 'wb-map chm-union))))
		  (unless (equal? chm-union-as-wbm wbm-union)
		    (let ((ch-only wb-only (map-difference-2 chm-union-as-wbm wbm-union)))
 		      (error "ch-map union failed: ~A, ~A" ch-only wb-only))))
		(check-pref chm-union chm "Map union"))
	      (let ((chm-intersection (map-intersection chm saved-chm #'filter-mod-8)))
		(test (verify chm-intersection))
		(let ((wbm-intersection (map-intersection wbm saved-wbm #'filter-mod-8))
		      ((chm-int-as-wbm (convert 'wb-map chm-intersection))))
		  (test (equal? chm-int-as-wbm wbm-intersection)))
		(check-pref chm-intersection chm "Map intersection"))
	      (let ((chm-diff-2a chm-diff-2b (map-difference-2 chm saved-chm))
		    (wbm-diff-2a wbm-diff-2b (map-difference-2 wbm saved-wbm)))
		(test (verify chm-diff-2a))
		(test (verify chm-diff-2b))
		(test (equal? (convert 'wb-map chm-diff-2a) wbm-diff-2a))
		(test (equal? (convert 'wb-map chm-diff-2b) wbm-diff-2b))
		(check-pref chm-diff-2a chm "Map difference-2")
		(check-pref chm-diff-2b saved-chm "Map difference-2" t)
		(let ((chm-diff-a (with-default (map-difference chm saved-chm) nil)))
		  (check-pref chm-diff-a chm "Map difference")
		  (test (equal? chm-diff-a chm-diff-2a)))
		(let ((chm-diff-b (with-default (map-difference saved-chm chm) nil)))
		  (check-pref chm-diff-b saved-chm "Map difference")
		  (test (equal? chm-diff-b chm-diff-2b))))
	      (let ((saved-chm-dom (domain saved-chm))
		    (saved-wbm-dom (domain saved-wbm))
		    ((ch-pos (restrict chm saved-chm-dom))
		     (ch-neg (restrict-not chm saved-chm-dom))
		     (wb-pos (restrict wbm saved-wbm-dom))
		     (wb-neg (restrict-not wbm saved-wbm-dom))))
		(test (verify ch-pos))
		(test (verify ch-neg))
		(test (equal? (convert 'wb-map ch-pos) wb-pos))
		(test (equal? (convert 'wb-map ch-neg) wb-neg)))))
	  (setq saved-wbm wbm)
	  (setq saved-chm chm))))))

(defmethod verify ((b ch-bag))
  (ch-bag-tree-verify (ch-bag-contents b) (hash-set-org-hash-fn (ch-bag-org b))))

(defmethod verify ((s transient-ch-bag))
  (ch-bag-tree-verify (transient-ch-bag-contents s) (hash-set-org-hash-fn (transient-ch-bag-org s))))

(defun test-champ-bags (n)
  (declare (optimize (speed 0) (debug 3)))
  (macrolet ((test (form)
	       `(let ((form-tested ',form))
		  (unless ,form
		    (error "Test failed: ~S" form-tested)))))
    (let ((saved-wbb nil)
	  (saved-chb nil))
      (dotimes (i n)
	(when (zerop (mod i 10))
	  (format t "."))
	(let ((cfn (if (zerop (mod (1+ i) 4)) 'erapmoc 'compare))
	      (wbb (wb-bag))
	      ((chb (ch-custom-bag cfn))
	       ((tchb (make-transient chb))))
	      (use-seq-of-symbols? (= 7 (ldb (byte 3 1) i))))
	  ;; Build up the bags with `with', occasionally `less'.
	  (dotimes (j (+ 8 (random 128)))
	    (let ((mi (if use-seq-of-symbols?
			  (@ *seq-of-symbols* (random (size *seq-of-symbols*)))
			(make-my-integer (random 64))))
		  (prev-wbb wbb)
		  (prev-chb chb))
	      (let ((mult (1+ (random 4))))
		(test (eqv (contains? chb mi mult) (contains? wbb mi mult)))
		(test (eqv (contains? tchb mi mult) (contains? wbb mi mult))))
	      (test (= (multiplicity chb mi) (multiplicity wbb mi)))
	      (test (or (empty? chb) (contains? chb (arb chb))))
	      (if (< (random 100) 30)
		  (let ((mult (1+ (random 3))))
		    (excludef wbb mi mult)
		    (excludef chb mi mult)
		    (exclude! tchb mi mult)
		    (test (or (contains? prev-wbb mi)
			      (eq chb prev-chb))))
		(let ((mult (1+ (random 3))))
		  (dotimes (k mult)
		    (includef wbb mi)
		    (includef chb mi)
		    (include! tchb mi))))
	      (test (= (multiplicity chb mi) (multiplicity wbb mi)))
	      (test (verify chb))
	      (test (verify tchb))
	      (test (= (size chb) (size wbb)))
	      (test (= (set-size chb) (set-size wbb)))
	      (test (eq (ch-bag-tree-compare (ch-bag-contents chb) (transient-ch-bag-contents tchb) #'compare)
			':equal))
	      (test (equal? (make-persistent tchb :copy? t) chb))
	      (test (equal? (convert 'wb-bag chb) wbb))
	      (test (eqv (subbag? chb prev-chb) (subbag? wbb prev-wbb)))
	      (let ((wbb-from-ch (convert 'wb-bag chb)))
		(unless (equal? wbb wbb-from-ch)
		  (error "ch-bag convert 'wb-bag or equal? failed")))
	      (test (eqv (subbag? chb prev-chb) (subbag? wbb prev-wbb)))
	      (when (let ((quot rem (floor j 8)))
		      (and (= 0 rem) (>= quot 1)))
		;; Test stateful iterators and at-index
		(let ((k 0)
		      (it (iterator chb))
		      (pit (iterator chb :pairs? t))
		      (f-it (fun-iterator chb))
		      (fp-it (fun-iterator chb :pairs? t))
		      (tp-it (make-ch-bag-tree-pair-iterator (transient-ch-bag-contents tchb))))
		  (do-bag (x chb)
		    (test (funcall it ':more?))
		    (test (equal? x (funcall it ':get)))
		    ;; Functional element iterator
		    (test (not (funcall f-it ':empty?)))
		    (test (equal? x (funcall f-it ':first)))
		    (setq f-it (funcall f-it ':rest)))
		  (test (funcall it ':done?))
		  (test (funcall f-it ':empty?))
		  ;; Check pair iteration (stateful and functional)
		  (do-bag-pairs (x mult chb)
		    (test (equal? x (at-index chb k)))
		    (incf k)
		    (test (= mult (multiplicity chb x)))
		    (test (funcall pit ':more?))
		    (let ((px pm (funcall pit ':get)))
		      (test (equal? x px))
		      (test (= mult pm)))
		    (test (not (funcall fp-it ':empty?)))
		    (let ((fpx fpm (funcall fp-it ':first)))
		      (test (equal? x fpx))
		      (test (= mult fpm)))
		    (setq fp-it (funcall fp-it ':rest))
		    (test (not (funcall tp-it ':done?)))
		    (let ((tpx tpm (funcall tp-it ':get)))
		      (test (equal? x tpx))
		      (test (= mult tpm))))
		  (test (funcall pit ':done?))
		  (test (funcall fp-it ':empty?))
		  (test (funcall tp-it ':done?)))
		;; Test GMap-based functional iteration
		(test (equal? (gmap (:result list) nil (:arg fun-sequence chb))
			      (convert 'list chb)))
		(test (equal? (gmap (:result alist) nil (:arg fun-bag-pairs chb))
			      (convert 'alist chb)))
		(test (equal? wbb (convert 'wb-bag chb)))
		(test (equal? chb (convert 'ch-bag (convert 'list chb) :compare-fn-name cfn)))
		(test (equal? chb (convert 'ch-bag (convert 'vector chb) :compare-fn-name cfn)))
		(test (equal? chb (convert 'ch-bag (convert 'seq chb) :compare-fn-name cfn)))
		;; Test alist conversions
		(test (equal? chb (convert 'ch-bag (convert 'alist chb) :from-type 'alist :compare-fn-name cfn))))))
	  ;; Two-bag operations against saved previous iteration
	  (when saved-chb
	    (flet ((check-pref (result label)
		     (let ((bad (gmap :or (fn (x) (let ((bx? bx (lookup result x)))
						    (and bx? (not (eq x bx)) x)))
				      (:arg ch-bag chb))))
		       (when bad
			 (error "~A failed left preference: ~A"
				label bad)))))
	      (let ((chb-union (union chb saved-chb))
		    (wbb-union (union wbb saved-wbb))
		    (chwbb-union (union chb saved-wbb)))
		(test (verify chb-union))
		(test (equal? (convert 'wb-bag chb-union) wbb-union))
		(test (equal? chwbb-union chb-union))
		(check-pref chb-union "union")
		(check-pref chwbb-union "union fallback"))
	      (let ((chb-int (intersection chb saved-chb))
		    (wbb-int (intersection wbb saved-wbb))
		    (chwbb-int (intersection chb saved-wbb)))
		(test (verify chb-int))
		(test (equal? (convert 'wb-bag chb-int) wbb-int))
		(test (equal? chwbb-int chb-int))
		(check-pref chb-int "intersection")
		(check-pref chwbb-int "intersection fallback"))
	      (let ((chb-diff (bag-difference chb saved-chb))
		    (wbb-diff (bag-difference wbb saved-wbb)))
		(test (verify chb-diff))
		(test (equal? (convert 'wb-bag chb-diff) wbb-diff))
		(check-pref chb-diff "bag-difference"))
	      (let ((chb-sum (bag-sum chb saved-chb))
		    (wbb-sum (bag-sum wbb saved-wbb))
		    (chwbb-sum (bag-sum chb saved-wbb)))
		(test (verify chb-sum))
		(test (equal? (convert 'wb-bag chb-sum) wbb-sum))
		(test (equal? chwbb-sum chb-sum))
		(check-pref chb-sum "bag-sum")
		(check-pref chwbb-sum "bag-sum fallback"))
	      (let ((chb-prod (bag-product chb saved-chb))
		    (wbb-prod (bag-product wbb saved-wbb))
		    (chwbb-prod (bag-product chb saved-wbb)))
		(test (verify chb-prod))
		(test (equal? (convert 'wb-bag chb-prod) wbb-prod))
		(test (equal? chwbb-prod chb-prod))
		(check-pref chb-prod "bag-product")
		(check-pref chwbb-prod "bag-product fallback"))))
	  ;; Test subbag? more thoroughly
	  (when saved-chb
	    (test (eqv (subbag? chb saved-chb) (subbag? wbb saved-wbb)))
	    (test (eqv (subbag? saved-chb chb) (subbag? saved-wbb wbb))))
	  ;; To get a good test for `disjoint?', we need different statistics -- given the above,
	  ;; disjointness is astronomically unlikely.  Choosing 55 out of 4096 gives roughly 50% odds.
	  ;; (Why so few?  The Birthday Paradox.)
	  (let ((wbb0 (gmap (:result wb-set) (fn (_i) (make-my-integer (random 4096))) (:arg index 0 55)))
		(wbb1 (gmap (:result wb-set) (fn (_i) (make-my-integer (random 4096))) (:arg index 0 55)))
		((chb0 (convert 'ch-set wbb0))
		 (chb1 (convert 'ch-set wbb1))))
	    (test (eqv (disjoint? chb0 chb1) (disjoint? wbb0 wbb1))))
	  ;; Test hash-value doesn't crash
	  (hash-value chb)
	  (setq saved-wbb wbb)
	  (setq saved-chb chb))))))


