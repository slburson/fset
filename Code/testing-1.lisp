(defun test-fset2-gmap ()
  (macrolet ((test (form)
	       `(unless ,form
		  (error "Test failed: ~S" ',form))))
    (test (equal? (gmap (:result list) nil (:arg set (wb-set 13 7 41 2)))
		  '(2 7 13 41)))
    (test (equal? (sort (gmap (:result list) nil (:arg set (ch-set 13 7 41 2))) #'<)
		  '(2 7 13 41)))
    (test (equal? (gmap (:result list) nil (:arg wb-set (wb-set 13 7 41 2)))
		  '(2 7 13 41)))
    (test (equal? (sort (gmap (:result list) nil (:arg ch-set (ch-set 13 7 41 2))) #'<)
		  '(2 7 13 41)))
    (test (equal? (gmap (:result set :filterp #'evenp) nil (:arg list '(8 3 14 6)))
		  (ch-set 8 14 6)))
    (test (equal? (gmap (:result ch-set :filterp #'evenp) nil (:arg list '(8 3 14 6)))
		  (ch-set 8 14 6)))
    (test (equal? (gmap (:result wb-set :compare-fn-name 'erapmoc) nil (:arg list '(8 3 14 6)))
		  (wb-custom-set 'erapmoc 8 3 14 6)))
    (test (equal? (gmap (:result ch-set :compare-fn-name 'erapmoc) nil (:arg list '(8 3 14 6)))
		  (ch-custom-set 'erapmoc 8 3 14 6)))
    (test (equal? (gmap (:result union) nil (:arg list (list (set 3 7) (set 9 1))))
		  (ch-set 1 3 7 9)))
    (test (equal? (gmap (:result intersection) nil (:arg list (list (set 3 7 9) (set 9 3))))
		  (ch-set 3 9)))

    (test (equal? (sort (gmap (:result list) nil (:arg bag (bag 3 7 (% 9 2)))) #'<)
		  '(3 7 9 9)))
    (test (equal? (gmap (:result list) nil (:arg wb-bag (wb-bag 3 7 (% 9 2))))
		  '(3 7 9 9)))
    (test (equal? (sort (gmap (:result list) nil (:arg ch-bag (ch-bag 3 7 (% 9 2)))) #'<)
		  '(3 7 9 9)))
    (test (equal? (sort (gmap (:result list) #'cons (:arg bag-pairs (bag 3 7 (% 9 2)))) #'< :key #'car)
		  '((3 . 1) (7 . 1) (9 . 2))))
    (test (equal? (gmap (:result list) #'cons (:arg wb-bag-pairs (wb-bag 3 7 (% 9 2))))
		  '((3 . 1) (7 . 1) (9 . 2))))
    (test (equal? (sort (gmap (:result list) #'cons (:arg ch-bag-pairs (bag 3 7 (% 9 2)))) #'< :key #'car)
		  '((3 . 1) (7 . 1) (9 . 2))))
    (test (equal? (sort (gmap (:result list) #'cons (:arg fun-bag-pairs (bag 3 7 (% 9 2)))) #'< :key #'car)
		  '((3 . 1) (7 . 1) (9 . 2))))
    (test (equal? (gmap (:result bag) nil (:arg list '(3 7 9 2 7 3)))
		  (ch-bag 2 (% 3 2) (% 7 2) 9)))
    (test (equal? (gmap (:result bag-pairs) (fn (x) (values (car x) (cdr x)))
			(:arg list '((a . 2) (b . 6) (q . 4))))
		  (ch-bag (% 'a 2) (% 'b 6) (% 'q 4))))
    (test (equal? (gmap (:result ch-bag :compare-fn-name 'erapmoc) nil (:arg list '(3 7 9 2 7 3)))
		  (ch-custom-bag 'erapmoc 2 (% 3 2) (% 7 2) 9)))
    (test (equal? (gmap (:result ch-bag-pairs :compare-fn-name 'erapmoc) (fn (x) (values (car x) (cdr x)))
			(:arg list '((a . 2) (b . 6) (q . 4))))
		  (ch-custom-bag 'erapmoc (% 'a 2) (% 'b 6) (% 'q 4))))
    (test (equal? (gmap (:result bag-sum) nil (:arg list (list (bag 2 2 3 3 3 4) (bag 1 2 4))))
		  (bag 1 (% 2 3) (% 3 3) (% 4 2))))
    (test (equal? (gmap (:result bag-product) nil (:arg list (list (bag 2 2 3 3 3 4) (bag 1 2 2 4))))
		  (bag (% 2 4) 4)))

    (test (equal? (sort (gmap (:result list) #'cons (:arg map (map ('a 3) ('b 7) ('c 6)))) #'string< :key #'car)
		  '((a . 3) (b . 7) (c . 6))))
    (test (equal? (sort (gmap (:result list) #'cons (:arg fun-map (map ('a 3) ('b 7) ('c 6)))) #'string< :key #'car)
		  '((a . 3) (b . 7) (c . 6))))
    (test (equal? (gmap (:result list) #'cons (:arg wb-map (wb-map ('a 3) ('b 7) ('c 6))))
		  '((a . 3) (b . 7) (c . 6))))
    (test (equal? (sort (gmap (:result list) #'cons (:arg ch-map (ch-map ('a 3) ('b 7) ('c 6))))
			#'string< :key #'car)
		  '((a . 3) (b . 7) (c . 6))))
    (test (equal? (gmap (:result map :filterp (fn (_x y) (< y 50)))
			#'values (:arg list '(foo bar baz)) (:arg list '(12 17 91)))
		  (ch-map ('foo 12) ('bar 17))))
    (test (equal? (gmap (:result map :default 0) #'values (:arg list '(foo bar baz)) (:arg list '(12 17 91)))
		  (ch-map ('foo 12) ('bar 17) ('baz 91) :default 0)))
    (test (equal? (gmap (:result map :no-default? t) #'values (:arg list '(foo bar baz)) (:arg list '(12 17 91)))
		  (ch-map ('foo 12) ('bar 17) ('baz 91) :no-default)))
    (test (equal? (gmap (:result wb-map) #'values (:arg list '(foo bar baz)) (:arg list '(12 17 91)))
		  (wb-map ('foo 12) ('bar 17) ('baz 91))))
    (test (equal? (gmap (:result ch-map :filterp (fn (_x y) (< y 50)))
			#'values (:arg list '(foo bar baz)) (:arg list '(12 17 91)))
		  (ch-map ('foo 12) ('bar 17))))
    (test (equal? (gmap (:result ch-map :default 0) #'values (:arg list '(foo bar baz)) (:arg list '(12 17 91)))
		  (ch-map ('foo 12) ('bar 17) ('baz 91) :default 0)))
    (test (equal? (gmap (:result ch-map :no-default? t) #'values (:arg list '(foo bar baz)) (:arg list '(12 17 91)))
		  (ch-map ('foo 12) ('bar 17) ('baz 91) :no-default)))
    (test (equal? (gmap (:result ch-map :filterp (fn (_x y) (< y 50)) :key-compare-fn-name 'erapmoc)
			#'values (:arg list '(foo bar baz)) (:arg list '(12 17 91)))
		  (ch-custom-map 'erapmoc nil ('foo 12) ('bar 17))))
    (test (equal? (gmap (:result ch-map :default 0 :key-compare-fn-name 'erapmoc)
			#'values (:arg list '(foo bar baz)) (:arg list '(12 17 91)))
		  (ch-custom-map 'erapmoc nil ('foo 12) ('bar 17) ('baz 91) :default 0)))
    (test (equal? (gmap (:result ch-map :no-default? t :key-compare-fn-name 'erapmoc)
			#'values (:arg list '(foo bar baz)) (:arg list '(12 17 91)))
		  (ch-custom-map 'erapmoc nil ('foo 12) ('bar 17) ('baz 91) :no-default)))
    (test (equal? (gmap (:result map-union) nil (:arg list (list (map ('a 7) ('b 4)) (map ('c 8) ('a 11)))))
		  (ch-map ('a 11) ('b 4) ('c 8))))
    (test (equal? (gmap (:result map-intersection) nil (:arg list (list (map ('a 7) ('b 4)) (map ('c 8) ('a 11)))))
		  (ch-map ('a 11))))
    (test (equal? (gmap (:result map-to-sets) #'values
			(:arg list '(a b a b c a))
			(:arg list '(0 1 2 3 4 5)))
		  (ch-map ('a (ch-set 0 2 5)) ('b (ch-set 1 3)) ('c (ch-set 4)) :default (ch-set))))
    (test (equal? (gmap (:result map-to-sets :key-compare-fn-name 'erapmoc) #'values
			(:arg list '(a b a b c a))
			(:arg list '(0 1 2 3 4 5)))
		  (ch-custom-map 'erapmoc nil ('a (ch-set 0 2 5)) ('b (ch-set 1 3)) ('c (ch-set 4)) :default (ch-set))))

    (test (equal? (gmap (:result list) nil (:arg seq (seq 3 'foo 99)))
		  '(3 foo 99)))
    (test (equal? (gmap (:result list) nil (:arg seq (seq 3 'foo 99 42 "hello" 'fizzbuzz)
						 :start 1 :end 5))
		  '(foo 99 42 "hello")))
    (test (equal? (gmap (:result list) nil (:arg seq (seq 3 'foo 99) :from-end? t))
		  '(99 foo 3)))
    (test (equal? (gmap (:result list) nil (:arg seq (seq 3 'foo 99 42 "hello" 'fizzbuzz)
						 :start 1 :end 5 :from-end? t))
		  '("hello" 42 99 foo)))
    (test (equal? (gmap (:result list) nil (:arg wb-seq (seq 3 'foo 99)))
		  '(3 foo 99)))
    (test (equal? (gmap (:result list) nil (:arg wb-seq (seq 3 'foo 99 42 "hello" 'fizzbuzz)
						 :start 1 :end 5))
		  '(foo 99 42 "hello")))
    (test (equal? (gmap (:result list) nil (:arg wb-seq (seq 3 'foo 99) :from-end? (> (get-universal-time) 1000000)))
		  '(99 foo 3)))
    (test (equal? (gmap (:result list) nil (:arg wb-seq (seq 3 'foo 99 42 "hello" 'fizzbuzz)
						 :start 1 :end 5 :from-end? (> (get-universal-time) 1000000)))
		  '("hello" 42 99 foo)))
    (test (equal? (gmap (:result seq :filterp #'integerp) nil (:arg list '(3 'bar 99)))
		  (seq 3 99)))
    (test (equal? (gmap (:result concat) nil (:arg list (list (seq 'now 'is) (seq 'the 'time))))
		  (seq 'now 'is 'the 'time)))))
