;;; CHAMP testing

(defmethod hash-value ((x my-integer))
  ;; Drop the two low-order bits to force collisions, and spread the bits out to force more levels
  ;; to be created.  Also, values equal mod 1024 will have the same hash.
  (let ((val (ash (my-integer-value x) -2)))
    (dpb (ldb (byte 2 6) val)
	 (byte 2 15)
	 (dpb (ldb (byte 2 4) val)
	      (byte 2 10)
	      (dpb (ldb (byte 2 2) val)
		   (byte 2 5)
		   (ldb (byte 2 0) val))))))

(defmethod verify ((s ch-set))
  (ch-set-tree-verify (ch-set-contents s) (hash-set-org-hash-fn (ch-set-org s))))

(defmethod verify ((s transient-ch-set))
  (ch-set-tree-verify (transient-ch-set-contents s) (hash-set-org-hash-fn (transient-ch-set-org s))))

(defparameter *seq-of-symbols*
  (let ((syms (seq)))
    (do-external-symbols (sym :cl)
      (push-last syms sym))
    syms))

(defun test-champ-transient-internals ()
  (macrolet ((test (form)
	       `(progn
		  ;; (format t "Trying: ~S~%" ',form)
		  (unless ,form
		    (error "Test failed: ~S" ',form)))))
    (flet ((match? (result pattern)
	     "A single `x' matches anything; `xx' matches any subsequence, but can be used only once."
	     (let ((xx-pos (position 'xx pattern)))
	       (if xx-pos
		   (and (gmap :and #'eql
			      (:arg vector result)
			      (:arg vector (subseq pattern 0 xx-pos)))
			(gmap :and #'eql
			      (:arg vector (subseq result (- (length result) (- (length pattern) xx-pos 1))))
			      (:arg vector (subseq pattern (1+ xx-pos)))))
		 (and (= (length result) (length pattern))
		      (gmap :and (fn (res-elt pat-elt)
				   (or (eq pat-elt 'x) (eql res-elt pat-elt)))
			    (:arg vector result)
			    (:arg vector pattern)))))))
      ;; Sets
      (test (let ((n1 (vector 3 12 4 0 'a 'b 42 'd 'c))
