		    (map (3 3) :default t)))
      (test (equal? (filter #'eql (ch-map (1 2) (2 3) (3 3) (4 5) :default t))
		    (ch-map (3 3) :default t)))

      (test (equal? (image (lambda (k v) (values (1+ k) (+ v 2)))
